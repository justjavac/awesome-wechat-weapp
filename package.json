{
  "name": "awesome-wechat-weapp",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "import:readme": "tsx scripts/import-readme.ts",
    "generate": "tsx scripts/generate.ts",
    "generate:check": "tsx scripts/generate.ts --check",
    "typecheck": "tsc --noEmit",
    "validate": "tsx scripts/validate-data.ts",
    "check": "npm run typecheck && npm run validate && npm run generate:check",
    "check:links": "tsx scripts/check-links.ts",
    "site": "tsx scripts/serve.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "yaml": "^2.9.0"
  }
}
